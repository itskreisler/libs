{
  "name": "@kreisler/ttlcache",
  "version": "1.0.0",
  "description": "Time-to-live cache utility library",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup --entry.index src/index.ts --format esm,cjs --dts --clean",
    "watch": "tsup --entry.index src/index.ts --format esm --clean --watch",
    "test:spec": "cross-env NODE_ENV=test tsx --test test/test.spec.ts",
    "lint": "eslint src test",
    "publish": "npm publish --access public"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/node": "latest",
    "cross-env": "latest",
    "eslint": "latest",
    "nodemon": "latest",
    "ts-node": "latest",
    "tsup": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest"
  }
}